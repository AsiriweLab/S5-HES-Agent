# =============================================================================
# S5-HES Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# All values shown are defaults - you only need to set what you want to change.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Smart-HES Agent
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
RELOAD=true
WORKERS=1

# -----------------------------------------------------------------------------
# LLM Provider Settings
# -----------------------------------------------------------------------------
# Active LLM provider: "ollama" (local), "openai" (cloud), "gemini" (cloud)
# Only ONE provider is active at a time. Set the corresponding API key below.
LLM_PROVIDER=ollama

# --- Ollama (local inference - no API key needed) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# --- OpenAI (cloud - requires API key) ---
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# --- Google Gemini (cloud - requires API key) ---
# Get your key from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Common LLM settings
LLM_TIMEOUT=120
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# RAG / ChromaDB Settings
# -----------------------------------------------------------------------------
# ChromaDB storage path (relative to backend/ or absolute)
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ChromaDB collection name
CHROMA_COLLECTION_NAME=smart_hes_knowledge

# Embedding model: "all-MiniLM-L6-v2" (384D, fast) or "gte-large" (1024D, high quality)
# IMPORTANT: Must match the model used to create the ChromaDB data
EMBEDDING_MODEL=gte-large

# RAG search settings
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.25

# -----------------------------------------------------------------------------
# Hybrid Search Settings
# -----------------------------------------------------------------------------
# Search mode: "semantic_only", "keyword_only", "hybrid", "auto"
SEARCH_MODE=hybrid
HYBRID_SEMANTIC_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3
HYBRID_FUSION_METHOD=rrf

# -----------------------------------------------------------------------------
# Text Chunking Settings
# -----------------------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# -----------------------------------------------------------------------------
# Anti-Hallucination / Verification Settings
# -----------------------------------------------------------------------------
VERIFICATION_ENABLED=true
CONFIDENCE_THRESHOLD_PASS=0.85
CONFIDENCE_THRESHOLD_FLAG=0.70
STRICT_VERIFICATION_MODE=false
REQUIRE_SOURCE_CITATION=true
MAX_HALLUCINATION_TOLERANCE=0.0

# -----------------------------------------------------------------------------
# Simulation Settings
# -----------------------------------------------------------------------------
SIMULATION_TIME_COMPRESSION=1440
MAX_DEVICES=100
MAX_ROOMS=20
DEFAULT_SIMULATION_DURATION_HOURS=24

# -----------------------------------------------------------------------------
# Path Settings
# -----------------------------------------------------------------------------
KNOWLEDGE_BASE_PATH=../knowledge_base
EXPORTS_PATH=../exports
CONFIGS_PATH=../configs
LOGS_PATH=./logs

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# =============================================================================
# Notes:
# - If using Ollama: must be running before starting the backend
# - If using OpenAI/Gemini: uncomment and set the appropriate API key above
# - ChromaDB data must be downloaded from Google Drive (see README.md)
# - Embedding model weights: downloaded automatically or from Google Drive
# =============================================================================
